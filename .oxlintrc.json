{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["react", "typescript", "unicorn", "react-perf", "oxc", "import", "node", "promise"],
  "categories": {
    "correctness": "error",
    "pedantic": "warn"
  },
  "rules": {
    "max-lines-per-function":"allow",
    "no-inline-comments": "allow"
  },
  "settings": {
    "react": {
      "formComponents": [],
      "linkComponents": [],
      "componentWrapperFunctions": []
    }
  },
  "env": {
    "builtin": true
  },
  "globals": {},
  "ignorePatterns": ["dist/"]
}